# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WSS_URL=wss://api.devnet.solana.com
# Production: use Helius or QuickNode for <200ms WSS delivery
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# SOLANA_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ── ArPay Program ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_ARPAY_PROGRAM_ID=ARPay1111111111111111111111111111111111111111
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# USDC mint (devnet test token)
NEXT_PUBLIC_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ── Oracle Bridge (server-only) ────────────────────────────────────────────────
ARPAY_PROGRAM_ID=ARPay1111111111111111111111111111111111111111
# Base58 secret key of the ArPay authority keypair — NEVER expose client-side
ARPAY_AUTHORITY_KEY=your_base58_secret_key_here
TREASURY_TOKEN_ACCT=your_treasury_usdc_token_account_here

# ── Xendit ────────────────────────────────────────────────────────────────────
# Test key prefix: xnd_development_
# Live key prefix: xnd_production_
XENDIT_API_KEY=xnd_development_YOUR_KEY_HERE
XENDIT_WEBHOOK_TOKEN=your_xendit_webhook_verification_token

# ── NMID Registry ─────────────────────────────────────────────────────────────
NMID_REGISTRY_URL=http://localhost:3001/registry

# ── Rate API ──────────────────────────────────────────────────────────────────
# Optional: override composite IDR/USD rate source
RATE_API_PRIMARY=https://api.exchangerate.host/latest?base=USD&symbols=IDR
RATE_CACHE_TTL_MS=5000

# ── Pyth Network ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_PYTH_FEED_USDC_USD=Gnt27xtC473ZT2Mw5u8wZ68Z3gULkSTb5DuxJy7eJotD

# ── Logging / Monitoring ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
